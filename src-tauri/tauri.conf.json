{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "usdbee",
  "identifier": "com.tbyr.usdbee",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "usdbee",
        "width": 800,
        "height": 600,
        "visible": false,
        "additionalBrowserArgs": "--ignore-gpu-blocklist --js-flags=--max-old-space-size=16384",
        "backgroundColor": "#1e1e1e",
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "/*/**",
          "$TEMP/**",
          "$LOCAL_DATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
